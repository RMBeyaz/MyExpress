Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.myexpress\.com\.tr$ [NC]
  RewriteRule ^ https://myexpress.com.tr%{REQUEST_URI} [R=301,L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(self), payment=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

<FilesMatch "^(\.cpanel\.yml|database\.sql|README.*|composer\.(json|lock)|package(-lock)?\.json|.*\.log)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.(env|ini|bak|backup|old|orig|swp|sql)$">
  Require all denied
</FilesMatch>
